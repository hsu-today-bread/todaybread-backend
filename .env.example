# MYSQL DATABASE 
MYSQL_DATABASE=todaybread
MYSQL_USER=todaybread
MYSQL_PASSWORD=todaybread
MYSQL_ROOT_PASSWORD=rootpassword

# JWT SECRET KEY
# openssl rand -base64 32 can be worked for this.
JWT_SECRET=your-production-secret-key-at-least-32-bytes-long-change-this

# Toss Payments API Keys
# TEST MODE: prefix test_sk
# LIVE MODE: prefix live_sk
TOSS_SECRET_KEY=test_sk_your_secret_key_here
TOSS_CLIENT_KEY=test_ck_your_client_key_here
